# VoiceLoop 环境配置
# 可选覆盖。默认值对本地 macOS 语音备忘录工作流是安全的。

# 语音备忘录源目录（默认已指向系统目录，一般无需修改）
VOICELOOP_SOURCE_DIR="~/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/"

# 数据输出目录
VOICELOOP_DATA_DIR="./data"

# 项目根目录
VOICELOOP_REPO_ROOT="."

# ASR API 配置（仅当使用 api 引擎时需要）
# VOICELOOP_ASR_API_URL="https://api.openai.com/v1/audio/transcriptions"
# VOICELOOP_ASR_API_KEY="sk-..."
# VOICELOOP_ASR_API_MODEL="whisper-1"

# Kimi API Key（可选，默认会读取 ~/.kimi/credentials/kimi-code.json）
# KIMI_API_KEY="..."
