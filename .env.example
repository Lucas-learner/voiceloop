# VoiceLoop configuration
# Copy this file to .env and fill in your values

# Voice Memos source directory
VOICELOOP_SOURCE_DIR="~/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/"
VOICELOOP_DATA_DIR="./data"
VOICELOOP_REPO_ROOT="."

# ---------------------------------------------------------------------------
# Kimi API configuration (required for AI meeting minutes and weekly reports)
# ---------------------------------------------------------------------------
# Option 1: Standard API Key (recommended)
# Get your key from: https://platform.kimi.com/
KIMI_API_KEY=""

# Base URL - choose one:
# OpenAI-compatible: https://api.kimi.com/coding/v1
# Anthropic-compatible: https://api.kimi.com/coding/
KIMI_BASE_URL="https://api.kimi.com/coding/v1"

# Option 2: Use Kimi CLI credentials (fallback if KIMI_API_KEY is not set)
# Requires 'kimi login' to create ~/.kimi/credentials/kimi-code.json

# ---------------------------------------------------------------------------
# Optional: External ASR API (instead of local MLX)
# ---------------------------------------------------------------------------
# VOICELOOP_ASR_API_URL="https://api.openai.com/v1/audio/transcriptions"
# VOICELOOP_ASR_API_KEY=""
# VOICELOOP_ASR_API_MODEL="whisper-1"
