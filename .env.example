# VoiceLoop 环境配置
# 可选覆盖。默认值对本地 macOS 语音备忘录工作流是安全的。

# 语音备忘录源目录（默认已指向系统目录，一般无需修改）
VOICELOOP_SOURCE_DIR="~/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/"

# 数据输出目录
VOICELOOP_DATA_DIR="./data"

# iCloud 同步目录（纪要和周报自动同步到此）
VOICELOOP_SYNC_DIR="~/Library/Mobile Documents/com~apple~CloudDocs/数据同步/voiceloop"

# 项目根目录
VOICELOOP_REPO_ROOT="."

# ---------------------------------------------------------------------------
# Kimi API 配置（AI 纪要生成必需）
# ---------------------------------------------------------------------------
# 方式1：标准 API Key（推荐）
# 从 https://platform.kimi.com/ 获取
KIMI_API_KEY=""

# Base URL：
# OpenAI-compatible: https://api.kimi.com/coding/v1
# Anthropic-compatible: https://api.kimi.com/coding/
KIMI_BASE_URL="https://api.kimi.com/coding/v1"

# 方式2：使用 Kimi CLI 凭证（当 KIMI_API_KEY 未设置时回退）
# 需要先运行 'kimi login' 生成 ~/.kimi/credentials/kimi-code.json

# ---------------------------------------------------------------------------
# 可选：外部 ASR API（替代本地 MLX）
# ---------------------------------------------------------------------------
# VOICELOOP_ASR_API_URL="https://api.openai.com/v1/audio/transcriptions"
# VOICELOOP_ASR_API_KEY="sk-..."
# VOICELOOP_ASR_API_MODEL="whisper-1"
